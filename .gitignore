```
# Kotlin/Android build artifacts
*.class
*.dex
*.jar
*.war
*.apk
*.aar

# Android specific
build/
.gradle/
local.properties
.pro
.cxx/
.externalNativeBuild/

# IDE files
.idea/
*.iml
*.ipr
*.iws
.vscode/

# Compiled files
*.o
*.obj
*.so
*.dll
*.dylib

# Logs
*.log

# Temp files
*.tmp
*.temp

# Environment
.env
.env.local
.env.*

# Coverage reports
coverage/
htmlcov/
.coverage

# Python cache (if any Python files exist in project)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
```