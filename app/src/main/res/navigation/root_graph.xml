<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.uzuu.admin.feature.login.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_login_to_scan"
            app:destination="@id/scanFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/scanFragment"
        android:name="com.uzuu.admin.feature.scan.ScanFragment"
        android:label="Scan">

        <action
            android:id="@+id/action_scan_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/root_graph"
            app:popUpToInclusive="true"/>
    </fragment>

</navigation>